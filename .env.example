# CorpusAgent configuration — copy to .env and fill in real values.
# The .env file is git-ignored and must never be committed.

# --- Qwen Cloud (Alibaba Cloud DashScope) -----------------------------------
# Required for cloud escalation. International (Singapore) account keys must use
# the intl endpoint below; mainland-China accounts use the .aliyuncs.com URL.
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
CORPUS_CLOUD_MODEL=qwen-plus

# --- Ollama (edge) ----------------------------------------------------------
# OLLAMA_HOST=http://localhost:11434
# CORPUS_LOCAL_MODEL=qwen2.5:7b
# CORPUS_EMBED_MODEL=nomic-embed-text
